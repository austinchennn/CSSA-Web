{
  "kind": "collectionType",
  "collectionName": "past_events",
  "info": {
    "singularName": "past-event",
    "pluralName": "past-events",
    "displayName": "往期活动",
    "description": "已结束的历史活动回顾"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "event_name": {
      "type": "string",
      "required": true
    },
    "introduction": {
      "type": "richtext",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "event_date": {
      "type": "date",
      "required": true
    }
  }
}
