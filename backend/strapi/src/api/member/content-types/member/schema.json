{
  "_comment": "Strapi Content Type Schema — Members (Collection Type)",
  "_field_definitions": {
    "kind": "collectionType",
    "collectionName": "members",
    "attributes": {
      "name": { "type": "string", "required": true, "description": "成员姓名" },
      "title": { "type": "string", "required": true, "description": "职位 Title，如'主席'、'市场部部长'" },
      "photo": {
        "type": "media",
        "multiple": false,
        "required": true,
        "allowedTypes": ["images"],
        "description": "成员展示图片（强制必填，统一风格照片）"
      },
      "order": { "type": "integer", "default": 0, "description": "排序权重，越大越靠前。同部门内按此字段倒序渲染" },
      "department": {
        "type": "relation",
        "relation": "manyToOne",
        "target": "api::department.department",
        "inversedBy": "members",
        "required": true,
        "description": "外键，关联 Departments 表"
      }
    }
  }
}
