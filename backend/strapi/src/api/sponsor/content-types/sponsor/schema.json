{
  "kind": "collectionType",
  "collectionName": "sponsors",
  "info": {
    "singularName": "sponsor",
    "pluralName": "sponsors",
    "displayName": "赞助商",
    "description": "赞助合作企业/机构，按档位（gold/silver/bronze）展示在前台 /sponsors 页面"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "website_url": {
      "type": "string"
    },
    "tier": {
      "type": "enumeration",
      "enum": ["gold", "silver", "bronze"],
      "default": "bronze",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "display_order": {
      "type": "integer",
      "default": 0
    }
  }
}
