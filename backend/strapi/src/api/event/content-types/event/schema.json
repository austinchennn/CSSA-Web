{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "活动",
    "description": "当前及待办活动，含动态报名表单"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "start_time": {
      "type": "datetime",
      "required": true
    },
    "capacity": {
      "type": "integer"
    },
    "form_schema": {
      "type": "json",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["upcoming", "active", "closed"],
      "default": "upcoming",
      "required": true
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::registration.registration",
      "mappedBy": "event"
    }
  }
}
