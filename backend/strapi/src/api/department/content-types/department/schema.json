{
  "kind": "collectionType",
  "collectionName": "departments",
  "info": {
    "singularName": "department",
    "pluralName": "departments",
    "displayName": "部门 Department",
    "description": "社团各部门信息，成员归属的数据来源"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "leader_name": {
      "type": "string",
      "required": false
    },
    "leader_introduction": {
      "type": "text",
      "required": false
    },
    "introduction": {
      "type": "text",
      "required": false
    },
    "benefits": {
      "type": "text",
      "required": false
    },
    "members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::member.member",
      "mappedBy": "department"
    }
  }
}
