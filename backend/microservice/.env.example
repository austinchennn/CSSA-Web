# ── NestJS 微服务配置 ──────────────────────────────────────────
# 复制此文件为 .env，填入真实值后启动服务
# cp .env.example .env

# 微服务监听端口（默认 3002，不与 Next.js 3000/3001 冲突）
PORT=3002

# ── Strapi 连接 ────────────────────────────────────────────────
# Strapi CMS 的内网地址（本地开发固定 localhost:1337）
STRAPI_URL=http://localhost:1337

# Strapi Full-Access API Token
# 获取方式：
#   1. 打开 http://localhost:1337/admin
#   2. 左侧菜单 Settings → API Tokens → Create new API Token
#   3. Name: microservice-token, Token type: Full access
#   4. 点击 Save，复制生成的 token 填在下面
STRAPI_API_TOKEN=在这里粘贴你的token

# ── Redis（BullMQ 队列）────────────────────────────────────────
# 本地 Docker Redis 地址
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS 允许的前端地址 ────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# ── SMTP 邮件配置（Task 8 P2，实现邮件发送时填入）─────────────
# TODO Task 8: 接入 Nodemailer SMTP，实现报名确认 / 状态变更邮件
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="UTMCSSA <noreply@utmcssa.ca>"
